{
  "name": "telegram-affiliate-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise Telegram affiliate bot with multi-level commission tracking, real-time analytics, and AI-enhanced development workflow",
  "keywords": [
    "telegram-bot",
    "affiliate-marketing",
    "cloudflare-workers",
    "bun",
    "typescript",
    "vue3",
    "monorepo",
    "commission-tracking",
    "grammy",
    "hono",
    "multi-level-marketing",
    "referral-system",
    "edge-computing",
    "d1-database",
    "turborepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/brendadeeznuts1111/telegram-affiliate.git"
  },
  "homepage": "https://github.com/brendadeeznuts1111/telegram-affiliate#readme",
  "bugs": {
    "url": "https://github.com/brendadeeznuts1111/telegram-affiliate/issues"
  },
  "author": "brendadeeznuts1111",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter='*' dev",
    "dev:bot": "cd src && bun --watch index.ts",
    "dev:api": "bun --filter=api dev",
    "dev:ui": "bun --filter=dashboard dev",
    "build": "bun run --filter='*' build",
    "build:ui": "cd apps/dashboard && bun run build",
    "start:api": "bun --filter=api start",
    "start:dashboard": "bun --filter=dashboard preview",
    "deploy:api:staging": "bun --filter=api deploy:staging",
    "deploy:api:prod": "bun --filter=api deploy:prod",
    "deploy:ui:staging": "bun run build:ui && bun --filter=dashboard deploy:staging",
    "deploy:ui:prod": "bun run build:ui && bun --filter=dashboard deploy:prod",
    "deploy:staging": "bun run deploy:api:staging && bun run deploy:ui:staging",
    "deploy:prod": "bun run deploy:api:prod && bun run deploy:ui:prod",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "clean:cache": "bun pm cache clean && echo '✅ Bun cache cleared'",
    "clean:build": "rm -rf apps/*/dist apps/*/.wrangler && echo '✅ Build artifacts removed'",
    "clean:db-temp": "rm -f data/*.db-shm data/*.db-wal && echo '✅ SQLite temp files removed'",
    "clean:processes": "pkill -f 'bun.*dev' || true && pkill -f 'wrangler' || true && echo '✅ Dev processes stopped'",
    "clean:maintenance": "bun run clean:processes && bun run clean:db-temp && bun run clean:build && bun run clean:cache && echo '🎉 Full maintenance cleanup complete!'",
    "logs:api:staging": "bunx wrangler tail telegram-affiliate-api-staging",
    "logs:api:prod": "bunx wrangler tail telegram-affiliate-api",
    "db:create": "bunx wrangler d1 create affiliate-system",
    "db:create:staging": "bunx wrangler d1 create affiliate-system-staging",
    "db:execute": "bunx wrangler d1 execute affiliate-system --file=apps/api/src/db/migrations/001_initial.sql",
    "db:execute:staging": "bunx wrangler d1 execute affiliate-system-staging --file=apps/api/src/db/migrations/001_initial.sql",
    "secret:put": "bunx wrangler secret put",
    "type-check": "cd apps/api && bunx tsc --noEmit && cd ../dashboard && bunx vue-tsc --noEmit",
    "lint": "bunx prettier --check .",
    "format": "bunx prettier --write .",
    "changeset": "bunx @changesets/cli",
    "version": "bunx @changesets/cli version",
    "release": "bunx @changesets/cli publish",
    "affected:build": "bunx turbo run build --filter=...[origin/main]",
    "affected:test": "bunx turbo run test --filter=...[origin/main]",
    "clean:all": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/.wrangler",
    "docker:build": "docker build -t telegram-affiliate .",
    "docker:dev": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:report": "bunx playwright show-report",
    "lighthouse": "cd apps/dashboard && bunx lighthouse-ci autorun",
    "ship": "bun scripts/ship.ts",
    "ship:staging": "bun scripts/ship.ts --staging-only",
    "ship:fast": "bun scripts/ship.ts --skip-tests",
    "launch:affiliate": "bun scripts/launch-affiliate.ts",
    "fix:critical": "bun scripts/fix-critical-issues.ts",
    "demo:cli": "bun scripts/demo-cli-features.ts",
    "demo:cli:debug": "bun scripts/demo-cli-features.ts --debug",
    "verify": "bun scripts/verify-setup.ts",
    "verify:full": "bun scripts/verify-setup.ts --verbose"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@playwright/test": "^1.40.0",
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "playwright": "^1.40.0",
    "prettier": "^3.6.2",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0",
    "wrangler": "^3.57.0"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.0",
    "grammy": "^1.38.2",
    "qrcode": "^1.5.4",
    "zod": "^4.1.12"
  }
}
