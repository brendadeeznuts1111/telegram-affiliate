{
  "name": "api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 3001",
    "dev:local": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "deploy:staging": "wrangler deploy -e staging",
    "deploy:prod": "wrangler deploy -e production"
  },
  "dependencies": {
    "@affiliate/schemas": "workspace:*",
    "hono": "^4.10.1",
    "zod": "^3.22.4"
  }
}
