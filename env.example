# ============================================
# Telegram Bot Configuration (REQUIRED)
# ============================================
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username
ADMIN_IDS=123456789,987654321

# ============================================
# Database Configuration
# ============================================
DB_PATH=./data/affiliate_system.db
DATABASE_PATH=./data/affiliate_system.db
DB_JOURNAL_MODE=WAL
DB_FOREIGN_KEYS=true

# ============================================
# Commission Settings
# ============================================
COMMISSION_DIRECT=5
COMMISSION_SUPER=2
COMMISSION_CURRENCY=USD

# ============================================
# API Configuration
# ============================================
PORT=3001
API_PORT=3001
HOST=localhost
API_HOST=localhost
PUBLIC_URL=https://telegram-affiliate-api.workers.dev
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://localhost:3000

# ============================================
# Cloudflare Configuration (Production)
# ============================================
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_DATABASE_ID=your_d1_database_id
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id
WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Environment
# ============================================
NODE_ENV=development
ENVIRONMENT=development
LOG_LEVEL=debug

# ============================================
# Security
# ============================================
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# External Services
# ============================================
# TON Blockchain
TON_API_KEY=your_ton_api_key
TON_NETWORK=testnet

# TRON Blockchain
TRON_API_KEY=your_tron_api_key
TRON_NETWORK=shasta

# ============================================
# Feature Flags
# ============================================
ENABLE_WITHDRAWALS=false
ENABLE_QR_TRACKING=true
ENABLE_REAL_TIME_UPDATES=false
ENABLE_ANALYTICS=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Monitoring & Analytics
# ============================================
SENTRY_DSN=your_sentry_dsn
ANALYTICS_ID=your_analytics_id

# ============================================
# Development Only
# ============================================
DEBUG=true
MOCK_BLOCKCHAIN=true
SKIP_AUTH=false

